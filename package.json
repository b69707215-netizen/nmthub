{
  "name": "nmthub-site",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cd packages/web && bunx vite",
    "build": "bun run build:web && bun run prepare:pages",
    "build:web": "cd packages/web && bunx vite build",
    "prepare:pages": "node -e \"const fs=require('node:fs'); fs.rmSync('.output/public',{recursive:true,force:true}); fs.mkdirSync('.output',{recursive:true}); fs.cpSync('packages/web/dist','.output/public',{recursive:true});\"",
    "deploy": "bun run build && npx wrangler deploy --config wrangler.toml",
    "preview": "cd packages/web && bunx vite preview"
  },
  "devDependencies": {
    "@tursodatabase/api": "^1.9.2",
    "@types/bun": "1.3.14",
    "@types/semver": "^7.7.1",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "semver": "^7.7.2",
    "turbo": "2.9.18",
    "typescript": "5.9.3",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@libsql/client": "^0.17.2",
    "cloudflare": "^5.2.0",
    "pm2": "^7.0.1"
  }
}
